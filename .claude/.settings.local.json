{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(ls:*)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "Bash(npm list:*)",
      "Bash(brew list:*)",
      "Bash(pandoc --list-output-formats)",
      "Bash(pandoc --pdf-engine=xelatex --version)",
      "Bash(gh search:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "mcp__gemini__ask_gemini",
      "mcp__gemini__web_search",
      "Bash(which ffmpeg:*)",
      "Bash(which convert:*)",
      "Skill(update-config)"
    ],
    "ask": [
      "Bash(git branch -D)",
      "Bash(git checkout)",
      "Bash(git restore)",
      "Edit(*settings.json)",
      "Edit(*settings.local.json)"
    ],
    "deny": [
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(curl * > *.sh)",
      "Bash(curl * > *.py)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(/Users/mat/Documents)",
      "Edit(/Users/mat/Documents)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push origin master)",
      "Bash(git push origin main)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd)",
      "Bash(git clean -f)",
      "Bash(push --force)",
      "Bash(reset --hard)",
      "Bash(*>> .env*)",
      "Bash(*> .env*)",
      "Edit(*/Cowork/logs/*)",
      "Bash(*Cowork/logs*)"
    ]
  }
}
